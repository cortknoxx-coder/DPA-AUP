{
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/internal-api",
      "destination": "/api/internal-api"
    },
    {
      "source": "/internal-api/:path*",
      "destination": "/api/internal-api?path=:path*"
    }
  ],
  "crons": [
    { "path": "/api/cron/fleet-health", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/analytics-rollup", "schedule": "0 3 * * *" }
  ]
}
